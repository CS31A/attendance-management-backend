{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"ConnectionStrings": {
		"DefaultConnection": ""
	},
	"AppSettings": {
		"Token": "",
		"Issuer": "",
		"Audience": ""
	},
	"CookieSettings": {
		"AccessTokenExpirationMinutes": 15,
		"RefreshTokenExpirationDays": 7
	},
	"BulkData": {
		"MaxFileSizeBytes": 5242880,
		"MaxRows": 1000,
		"MaxPreviewRows": 250,
		"MaxIssues": 500
	},
	"AllowedEmailDomains": [
		"gmail.com",
		"outlook.com",
		"yahoo.com",
		"hotmail.com",
		"aol.com",
		"icloud.com",
		"protonmail.com",
		"yandex.com",
		"mail.com"
	],
	"AllowedHosts": "*",
	"TimeZoneSettings": {
		"TimeZoneId": "Asia/Manila"
	},
	"SessionAutoEnd": {
		"Enabled": true,
		"GraceMinutes": 15,
		"ScanIntervalMinutes": 5
