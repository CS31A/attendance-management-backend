	"FingerprintDeviceAuth": {
		"Devices": {
			"esp32-attendance-01": "REPLACE_DEVICE_API_KEY"
		}
	},
	"Kestrel": {
		"Endpoints": {
			"Http": {
				"Url": "http://0.0.0.0:8080"
			}
