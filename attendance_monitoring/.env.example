ConnectionStrings__DefaultConnection=Server=localhost;Database=YourDatabase;User=YourUser;Password=YourPassword;
# JWT Token must be at least 32 bytes (256 bits) for HMAC-SHA256 security
# Use a strong random string of at least 64 characters. Generate with: openssl rand -base64 48
AppSettings__Token=YourSuperSecretTokenThatIsAtLeast32BytesLongForSecurity123456789
AppSettings__Issuer=YourIssuer
AppSettings__Audience=YourAudience
CookieSettings__AccessTokenExpirationMinutes=15
CookieSettings__RefreshTokenExpirationDays=7
# CORS Settings - Separate multiple origins with semicolons (;)
CorsSettings__AllowedOrigins=http://localhost:5173;http://localhost:3000